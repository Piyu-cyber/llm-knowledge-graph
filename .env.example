# ==================== OmniProf v3.0 Configuration ====================
# Copy this file to .env and fill in your actual values

# ==================== JWT Security ====================
SECRET_KEY=your-secret-key-change-in-production-use-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== Groq API ====================
GROQ_API_KEY=your_groq_api_key_here

# ==================== Neo4j Graph Database ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ==================== Application Settings ====================
DEBUG=False
LOG_LEVEL=INFO

# ==================== CORS Settings ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:*

# ==================== Database ====================
# Future: PostgreSQL for user management (for now using in-memory)
DATABASE_URL=sqlite:///./omniprof.db

# ==================== Vector Store ====================
FAISS_INDEX_PATH=./rag_index.faiss
VECTOR_DIMENSION=384
