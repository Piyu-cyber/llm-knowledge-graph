# ==================== OmniProf v3.0 Configuration ====================
# Copy this file to .env and fill in your actual values

# ==================== JWT Security ====================
SECRET_KEY=0babb1ca1f3dfe4d8650ef13a16e90062d36a85e8420dc7a291ba003b1637c0f
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== Groq API ====================
GROQ_API_KEY=your_groq_api_key_here

# ==================== Cerebras API ====================
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ==================== Graph Database (RustWorkX) ====================
# RustWorkX uses JSON-based persistence, no connection needed
GRAPH_DATA_DIR=data

# ==================== Application Settings ====================
DEBUG=False
LOG_LEVEL=INFO

# ==================== CORS Settings ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:*

# ==================== Database ====================
# Future: PostgreSQL for user management (for now using in-memory)
DATABASE_URL=sqlite:///./omniprof.db

# ==================== Vector Store ====================
FAISS_INDEX_PATH=./rag_index.faiss
VECTOR_DIMENSION=384

# ==================== LLM Router ====================
LLMROUTER_BACKOFF_SECONDS=20
LLMROUTER_MAX_BACKOFF_SECONDS=180
LLMROUTER_FORCE_RATE_LIMIT=

# ==================== Integrity ====================
INTEGRITY_MIN_TOKENS=500

# ==================== Compliance Flags ====================
DATA_ENCRYPTION_AT_REST=true
TLS_ENFORCED=true

# ==================== Streaming ====================
WS_STREAM_CHUNK_MODE=token

# ==================== Memory ====================
MEMORY_INDEX_PATH=./episode_memory.faiss
